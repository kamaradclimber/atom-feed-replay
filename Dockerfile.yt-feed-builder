FROM golang:1-alpine AS builder
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN go build -o /yt-feed-builder ./cmd/yt-feed-builder/

FROM alpine:latest
RUN apk add --no-cache ca-certificates tzdata
COPY --from=builder /yt-feed-builder /yt-feed-builder
EXPOSE 8081
ENTRYPOINT ["/yt-feed-builder"]
